# GridSense AI .gitignore - Focused Production Build

# Environments
venv/
venv-external/
.env
.runtime/
.cache/
__pycache__/
*.pyc

# Data & Models (Do not commit large artifacts)
data/synthetic_scada/*.csv
data/weather/*.parquet
models/baseline/*.parquet
models/baseline/*.pkl
models/pinn/*.csv

# Logs & Temp
logs/
tmp/
.pytest_cache/
.streamlit/config.toml
reports/

# System
.DS_Store
.vscode/
.idea/
